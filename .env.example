# Gemini 2.5 Flash — get at aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here

# Gold price — get at gold-api.com
GOLD_API_KEY=your_gold_api_key_here

# Stock prices — free tier at alphavantage.co (25 calls/day)
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# Telegram — bot token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Telegram — your chat ID (message your bot, then check getUpdates)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

